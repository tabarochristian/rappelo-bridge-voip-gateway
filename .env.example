# ==========================================
# Rappelo Bridge VoIP Gateway - Environment
# ==========================================
# Copy this file to .env and customize values
# DO NOT commit .env to version control!

# ---- SIP Domain ----
# The SIP domain for your deployment (e.g., sip.yourcompany.com)
SIP_DOMAIN=sip.rappelo.local

# ---- Public IP ----
# Your server's public IP address (required for NAT traversal)
# Leave empty for local/LAN-only deployments
PUBLIC_IP=

# ---- Database ----
KAMAILIO_DB_NAME=kamailio
KAMAILIO_DB_USER=kamailio
KAMAILIO_DB_PASSWORD=kamailio-secret-change-me

# ---- STUN/TURN ----
# Shared secret for TURN authentication (change this!)
TURN_SECRET=rappelo-turn-secret-change-me
STUN_PORT=3478

# ---- SIP Ports ----
SIP_PORT=5060
SIP_TLS_PORT=5061

# ---- Admin Panel ----
ADMIN_PORT=8080

# ---- Twilio SIP Trunk (optional) ----
# To enable PSTN calling via Twilio Elastic SIP Trunking:
# 1. Create a trunk at https://console.twilio.com/us1/develop/voice/manage/sip-trunking
# 2. Set Termination URI below (e.g. your-trunk.pstn.twilio.com)
# 3. Add your server IP to Twilio's trunk Origination settings
TWILIO_TERMINATION_URI=

# ---- TLS ----
# Set to "true" to enable SIP-TLS on port 5061
ENABLE_TLS=false

# ---- Debug ----
# Set to "true" for verbose Kamailio logging
DEBUG=false
