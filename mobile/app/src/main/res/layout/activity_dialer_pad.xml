<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Top bar with back arrow -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_back"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_primary" />

    <!-- Number display area -->
    <TextView
        android:id="@+id/dialerNumberText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:hint="Enter number or USSD"
        android:maxLines="2"
        android:minHeight="64dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_disabled"
        android:textSize="36sp"
        android:fontFamily="sans-serif-light"
        app:layout_constraintEnd_toStartOf="@id/backspaceButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backButton" />

    <ImageButton
        android:id="@+id/backspaceButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Backspace"
        android:src="@drawable/ic_backspace"
        android:scaleType="centerInside"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/dialerNumberText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/dialerNumberText"
        app:tint="@color/text_secondary" />

    <!-- USSD response card (hidden by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/ussdResponseCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dialerNumberText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/ussdResponseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USSD Response"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ussdResponseText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_primary"
                android:textIsSelectable="true"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3" />

            <ProgressBar
                android:id="@+id/ussdProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ussdDismissButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="OK"
                android:textColor="@color/primary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Keypad grid -->
    <GridLayout
        android:id="@+id/keypadGrid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toTopOf="@id/actionButtonsRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key1"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="1"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key2"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="2"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key3"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="3"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key4"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="4"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key5"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="5"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key6"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="6"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key7"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="7"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key8"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="8"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key9"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="9"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyStar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="✱"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key0"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="0"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyHash"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1"
            android:text="#"
            android:textColor="@color/text_primary"
            android:textSize="28sp" />

    </GridLayout>

    <!-- Action buttons row: USSD (left), Call (center), nothing (right for balance) -->
    <LinearLayout
        android:id="@+id/actionButtonsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- USSD send button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/ussdActionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:contentDescription="Send USSD"
            app:backgroundTint="@color/primary"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_dialpad"
            app:tint="@android:color/white" />

        <!-- Call button (large green) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/callActionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Call"
            app:backgroundTint="@color/status_ok"
            app:fabCustomSize="72dp"
            app:maxImageSize="32dp"
            app:srcCompat="@drawable/ic_call"
            app:tint="@android:color/white" />

        <!-- Spacer for symmetry -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="32dp"
            android:visibility="invisible" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
